<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <group
        android:pivotX="256"
        android:pivotY="256"
        android:rotation="-25">
        
        <!-- Mouse Outer Body -->
        <path
            android:pathData="M 186,216 A 70,70 0 0,1 326,216 L 326,296 A 70,70 0 0,1 186,296 Z"
            android:fillColor="#991e1b4b"
            android:strokeWidth="12">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="256" android:startY="0" android:endX="256" android:endY="512">
                    <item android:offset="0.0" android:color="#ffffff" />
                    <item android:offset="1.0" android:color="#94a3b8" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Left/Right Click Separator Line -->
        <path
            android:pathData="M 256,146 L 256,231"
            android:strokeWidth="8"
            android:strokeLineCap="round">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="256" android:startY="0" android:endX="256" android:endY="512">
                    <item android:offset="0.0" android:color="#ffffff" />
                    <item android:offset="1.0" android:color="#94a3b8" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Glowing Scroll Wheel / Motion Indicator -->
        <path android:pathData="M 248,184 A 8,8 0 0,1 264,184 L 264,204 A 8,8 0 0,1 248,204 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear" android:startX="0" android:startY="512" android:endX="512" android:endY="0">
                    <item android:offset="0.0" android:color="#00f2fe" />
                    <item android:offset="0.5" android:color="#4facfe" />
                    <item android:offset="1.0" android:color="#9b51e0" />
                </gradient>
            </aapt:attr>
        </path>
    </group>

    <group>
        <!-- Large Sparkle (Top Right) -->
        <path android:pathData="M 385,115 Q 385,150 420,150 Q 385,150 385,185 Q 385,150 350,150 Q 385,150 385,115 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear" android:startX="0" android:startY="512" android:endX="512" android:endY="0">
                    <item android:offset="0.0" android:color="#00f2fe" />
                    <item android:offset="0.5" android:color="#4facfe" />
                    <item android:offset="1.0" android:color="#9b51e0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Medium Sparkle (Bottom Right) -->
        <path android:pathData="M 410,280 Q 410,300 430,300 Q 410,300 410,320 Q 410,300 390,300 Q 410,300 410,280 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear" android:startX="0" android:startY="512" android:endX="512" android:endY="0">
                    <item android:offset="0.0" android:color="#00f2fe" />
                    <item android:offset="0.5" android:color="#4facfe" />
                    <item android:offset="1.0" android:color="#9b51e0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Small Sparkle (Top Left) -->
        <path android:pathData="M 160,110 Q 160,125 175,125 Q 160,125 160,140 Q 160,125 145,125 Q 160,125 160,110 Z" android:fillAlpha="0.8">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear" android:startX="0" android:startY="512" android:endX="512" android:endY="0">
                    <item android:offset="0.0" android:color="#00f2fe" />
                    <item android:offset="0.5" android:color="#4facfe" />
                    <item android:offset="1.0" android:color="#9b51e0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Tiny Sparkle (Bottom Left) -->
        <path android:pathData="M 130,300 Q 130,310 140,310 Q 130,310 130,320 Q 130,310 120,310 Q 130,310 130,300 Z" android:fillAlpha="0.5">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear" android:startX="0" android:startY="512" android:endX="512" android:endY="0">
                    <item android:offset="0.0" android:color="#00f2fe" />
                    <item android:offset="0.5" android:color="#4facfe" />
                    <item android:offset="1.0" android:color="#9b51e0" />
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
